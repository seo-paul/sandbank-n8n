OBSIDIAN_BI_GUIDE_WORKFLOW_SCHEMA_DIR="Workflows/bi-guide-content/Schemas"
OBSIDIAN_BI_GUIDE_WORKFLOW_TEMPLATE_DIR="Workflows/bi-guide-content/Templates"
