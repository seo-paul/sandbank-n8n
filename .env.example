# Timezone
TZ=Europe/Berlin

# n8n
N8N_ENCRYPTION_KEY=replace_with_64_hex_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password
N8N_RUNNERS_TASK_TIMEOUT=1800
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Postgres (n8n)
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_strong_password

# Redis
REDIS_PASSWORD=replace_with_strong_password

# Local model (Ollama)
OLLAMA_MODEL=qwen3.5:27b
OLLAMA_MODEL_FALLBACK=llama3.2:latest
OLLAMA_BASE_URL=http://host.docker.internal:11434
WF90_MIN_QUALITY_SCORE=6.5
WF90_MIN_EVIDENCE_REFS=3
WF90_MIN_DRAFT_BODY_LEN=180

# Obsidian Local REST API
# Plugin default secure port is 27124 (self-signed TLS)
OBSIDIAN_REST_URL=https://host.docker.internal:27124
OBSIDIAN_REST_API_KEY=replace_with_obsidian_rest_api_key
OBSIDIAN_NOTES_DIR=Marketing/Social-Media/Beitraege
OBSIDIAN_WORKFLOW_DIR="Marketing/Social-Media/Workflow"
OBSIDIAN_WORKFLOW_LOGS_DIR="Marketing/Social-Media/Workflow/Workflow Logs"
OBSIDIAN_WORKFLOW_RESULTS_DIR="Marketing/Social-Media/Workflow/Workflow Ergebnisse"
OBSIDIAN_WORKFLOW_DRAFTS_DIR="Marketing/Social-Media/Workflow/Drafts"
OBSIDIAN_WORKFLOW_PROMPTS_DIR="Marketing/Social-Media/Workflow/Prompts"
OBSIDIAN_WORKFLOW_RESULTS_INDEX="Marketing/Social-Media/Workflow/Workflow Ergebnisse/00-Workflow-Ergebnisse.md"
OBSIDIAN_WORKFLOW_STEPS_FILE="Marketing/Social-Media/Workflow/Workflow Schritte.md"
OBSIDIAN_WORKFLOW_INTERMEDIATE_FILE="Marketing/Social-Media/Workflow/Workflow Zwischenergebnisse.md"
OBSIDIAN_WORKFLOW_OVERVIEW_FILE="Marketing/Social-Media/Workflow/Workflow Übersicht.md"
OBSIDIAN_ALLOW_INSECURE_TLS=false
