OBSIDIAN_WORKFLOW_RUNS_FILE="Workflows/social-content/Artefakte/Ergebnisse/00-Runs.md"
OBSIDIAN_WORKFLOW_OVERVIEW_FILE="Marketing/Social-Media/Beitraege/Beitraege-Workflow/Workflow-Uebersicht.md"
OBSIDIAN_WORKFLOW_RESULTS_OVERVIEW_FILE="Marketing/Social-Media/Beitraege/Beitraege-Workflow/Ergebnisse-Uebersicht.md"
OBSIDIAN_WORKFLOW_INTERMEDIATE_OVERVIEW_FILE="Marketing/Social-Media/Beitraege/Beitraege-Workflow/Zwischenergebnisse-Uebersicht.md"
OBSIDIAN_BI_GUIDE_WORKFLOW_DIR="Workflows/bi-guide-content"
OBSIDIAN_BI_GUIDE_MARKETING_DIR="Marketing/Content/BI-Guide/BI-Guide-Workflow"
OBSIDIAN_BI_GUIDE_WORKFLOW_RESULTS_DIR="Workflows/bi-guide-content/Artefakte/Ergebnisse"
