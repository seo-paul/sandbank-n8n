# Timezone
TZ=Europe/Berlin

# n8n
N8N_ENCRYPTION_KEY=replace_with_64_hex_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password
N8N_RUNNERS_TASK_TIMEOUT=1800
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Postgres (n8n)
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_strong_password

# Redis
REDIS_PASSWORD=replace_with_strong_password

# Local model (Ollama)
OLLAMA_MODEL=qwen3.5:27b
OLLAMA_BASE_URL=http://host.docker.internal:11434
PIPELINE_MIN_QUALITY_SCORE=70
PIPELINE_MIN_EVIDENCE_REFS=3
PIPELINE_MIN_DRAFT_BODY_LEN=180

# Obsidian Local REST API
# Plugin default secure port is 27124 (self-signed TLS)
OBSIDIAN_REST_URL=https://host.docker.internal:27124
OBSIDIAN_REST_API_KEY=replace_with_obsidian_rest_api_key
OBSIDIAN_NOTES_DIR=Marketing/Social-Media/Beitraege
OBSIDIAN_WORKFLOW_DIR="Marketing/Social-Media/Beitraege/Workflow"
OBSIDIAN_WORKFLOW_RESULTS_DIR="Marketing/Social-Media/Beitraege/Workflow/Ergebnisse"
OBSIDIAN_WORKFLOW_DETAIL_DIR="Marketing/Social-Media/Beitraege/Workflow/Ergebnisse/Laufdetails"
OBSIDIAN_WORKFLOW_ERROR_DIR="Marketing/Social-Media/Beitraege/Workflow/Ergebnisse/Fehlerdetails"
OBSIDIAN_WORKFLOW_INTERMEDIATE_DIR="Marketing/Social-Media/Beitraege/Workflow/Zwischenergebnisse"
OBSIDIAN_WORKFLOW_PROMPTS_DIR="Marketing/Social-Media/Beitraege/Workflow/Prompts"
OBSIDIAN_WORKFLOW_RUNS_FILE="Marketing/Social-Media/Beitraege/Workflow/Ergebnisse/00-Runs.md"
OBSIDIAN_WORKFLOW_OVERVIEW_FILE="Marketing/Social-Media/Beitraege/Workflow/Workflow Übersicht.md"
OBSIDIAN_ALLOW_INSECURE_TLS=false
