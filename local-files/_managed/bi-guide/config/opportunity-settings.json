{
  "search_console": {
    "enabled": true,
    "site_url": "",
    "scope": "https://www.googleapis.com/auth/webmasters.readonly",
    "collection_lag_days": 2,
    "backfill_days": 3,
    "row_limit": 25000,
    "max_rows_per_report": 50000,
    "minimum_impressions": 5,
    "report_types": [
      "query_country",
      "page_country"
    ]
  },
  "manual_signals": {
    "default_locale": "de",
    "allowed_sources": [
      "support",
      "demo",
      "changelog",
      "product_note",
      "sales",
      "founder_note"
    ],
    "max_signals": 200
  },
  "scoring": {
    "weights": {
      "demand_signal": 0.32,
      "business_fit": 0.22,
      "evidence_ready": 0.16,
      "freshness": 0.14,
      "gap_bonus": 0.1,
      "manual_priority_hint": 0.06
    },
    "default_business_fit": 0.55,
    "default_evidence_ready": 0.5,
    "refresh_priority_floor": 52,
    "net_new_priority_floor": 54
  },
  "classification": {
    "intent_rules": {
