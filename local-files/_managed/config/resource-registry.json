      "resource_id": "industry-benchmarks",
      "publisher": "Industry Benchmarks and Surveys",
      "domain_patterns": ["gartner.com", "forrester.com", "barc.com", "dresneradvisory.com", "mckinsey.com", "deloitte.com", "pwc.com", "kpmg.com"],
