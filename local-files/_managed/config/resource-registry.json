    },
    {
      "resource_id": "topic-research-direct",
      "publisher": "Direct Topic Research",
      "domain_patterns": ["arxiv.org", "nber.org", "nih.gov", "ssrn.com"],
      "resource_class": "topic_specific_research",
      "allowed_workflows": ["social", "bi-guide"],
      "allowed_usage": ["fact", "counterpoint", "background"],
      "manual_review_required": false,
      "bias_flags": [],
      "notes": "Nur bei direktem Themenfit verwenden."
    },
    {
      "resource_id": "operator-case-studies",
      "publisher": "Operator Case Studies",
      "domain_patterns": ["netflixtechblog.com", "shopify.engineering", "blog.cloudflare.com", "stripe.com", "engineering."],
      "resource_class": "operator_case_study",
      "allowed_workflows": ["social", "bi-guide"],
      "allowed_usage": ["example", "background", "counterpoint"],
      "manual_review_required": true,
      "bias_flags": ["single_company_view"],
      "notes": "Gut fuer reale Umsetzung, aber nicht als alleiniger Beleg."
    },
    {
      "resource_id": "reddit-community",
      "publisher": "Reddit",
      "domain_patterns": ["reddit.com"],
      "resource_class": "community_signal",
      "allowed_workflows": ["social"],
      "allowed_usage": ["background", "counterpoint"],
      "manual_review_required": false,
      "bias_flags": ["anecdotal"],
      "notes": "Nur als Community-Signal, nie als Kernbeleg."
    },
    {
      "resource_id": "general-tech-media",
      "publisher": "General Technology Media",
      "domain_patterns": ["techcrunch.com", "theverge.com", "wired.com", "venturebeat.com", "heise.de"],
      "resource_class": "general_media",
      "allowed_workflows": ["social", "bi-guide"],
      "allowed_usage": ["background", "counterpoint"],
      "manual_review_required": true,
      "bias_flags": ["second_hand_reporting"],
      "notes": "Nur fuer Marktbewegung oder Kontext, nicht fuer harte Kernclaims."
    },
    {
      "resource_id": "broad-science-review-only",
      "publisher": "Broad Science Publishers",
      "domain_patterns": ["nature.com", "sciencedirect.com", "springer.com"],
      "resource_class": "topic_specific_research",
      "allowed_workflows": ["social", "bi-guide"],
      "allowed_usage": ["background", "counterpoint"],
      "manual_review_required": true,
      "topic_keywords_any": ["analytics", "business intelligence", "dashboard", "reporting", "data warehouse", "data governance", "decision support"],
      "bias_flags": ["generic_science_domain_not_default_bi_source"],
      "notes": "Nur bei direktem BI-/Analytics-Fit und mit manueller Einordnung nutzen."
    },
    {
      "resource_id": "low-value-aggregators",
      "publisher": "Low Value Aggregators",
      "domain_patterns": ["medium.com", "substack.com", "wikipedia.org"],
      "resource_class": "low_value_aggregator",
      "allowed_workflows": [],
      "allowed_usage": ["background"],
      "manual_review_required": true,
      "bias_flags": ["aggregated_or_unsourced"],
      "notes": "Default nicht als Evidenz zulassen."
