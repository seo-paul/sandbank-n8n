  "publishers": [
    {
      "resource_id": "official-docs-generic",
      "publisher": "Official Product and Platform Docs",
      "domain_patterns": ["docs.", "developer.", "support.", "help.", "learn.microsoft.com", "developers.google.com", "cloud.google.com"],
      "resource_class": "official_product_or_platform_docs",
      "allowed_workflows": ["social", "bi-guide"],
      "allowed_usage": ["fact", "comparison", "background"],
      "manual_review_required": false,
      "bias_flags": [],
      "notes": "Default fuer Produkt-, API- und Plattformdokumentation."
