{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ObsidianNotePayload",
  "type": "object",
  "required": [
    "file_name",
    "description",
    "channel",
    "format",
    "status",
    "link",
    "markdown_body"
  ],
  "properties": {
    "file_name": { "type": "string", "minLength": 5 },
    "description": { "type": "string", "minLength": 10 },
    "channel": { "type": "string", "minLength": 2 },
    "format": { "type": "string", "minLength": 2 },
    "status": { "type": "string", "minLength": 2 },
    "link": { "type": "string" },
    "markdown_body": { "type": "string", "minLength": 30 }
  },
  "additionalProperties": false
}
