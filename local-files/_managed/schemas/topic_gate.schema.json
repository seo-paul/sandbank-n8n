{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TopicGate",
  "type": "object",
  "required": [
    "decision",
    "reason",
    "selected_angle_id",
    "selected_angle",
    "backup_angle",
    "linkedin_fit",
    "reddit_fit",
    "must_have_in_draft",
    "must_avoid",
    "open_risks"
  ],
  "properties": {
    "decision": { "type": "string", "enum": ["publish", "hold"] },
    "reason": { "type": "string", "minLength": 5 },
    "selected_angle_id": { "type": "string", "minLength": 2 },
    "selected_angle": {
      "type": "object",
      "required": ["title", "core_thesis", "audience_problem", "why_this_angle_wins", "why_now", "conversion_bridge", "must_use_evidence_refs", "counterpoint_or_caveat"],
      "properties": {
        "title": { "type": "string", "minLength": 5 },
        "core_thesis": { "type": "string", "minLength": 8 },
        "audience_problem": { "type": "string", "minLength": 5 },
        "why_this_angle_wins": { "type": "string", "minLength": 5 },
        "why_now": { "type": "string", "minLength": 5 },
        "conversion_bridge": { "type": "string", "minLength": 5 },
        "must_use_evidence_refs": { "type": "array", "minItems": 0, "items": { "type": "string", "minLength": 2 } },
        "counterpoint_or_caveat": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "backup_angle": {
      "type": "object",
      "required": ["title", "core_thesis"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "core_thesis": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "linkedin_fit": { "type": "number", "minimum": 0, "maximum": 1 },
    "reddit_fit": { "type": "number", "minimum": 0, "maximum": 1 },
    "must_have_in_draft": { "type": "array", "items": { "type": "string" } },
    "must_avoid": { "type": "array", "items": { "type": "string" } },
    "open_risks": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": { "const": "publish" }
        }
      },
      "then": {
        "properties": {
          "selected_angle": {
            "properties": {
              "must_use_evidence_refs": {
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
