{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LinkedInBrief",
  "type": "object",
  "required": [
    "recommended_format",
    "post_objective",
    "hook_options",
    "outline",
    "proof_points",
    "cta_options",
    "first_comment_goal",
    "reply_seed_topics",
    "hard_rules"
  ],
  "properties": {
    "recommended_format": { "type": "string", "enum": ["text", "document", "video", "poll"] },
    "post_objective": { "type": "string", "enum": ["conversation", "authority", "profile_visits", "link_clicks", "lead_gen"] },
    "hook_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "hook"],
        "properties": {
          "type": { "type": "string", "enum": ["bold_statement", "question", "stat", "story", "contrarian_take"] },
          "hook": { "type": "string", "minLength": 5 }
        },
        "additionalProperties": false
      }
    },
    "outline": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 3 } },
    "proof_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_ref", "point"],
        "properties": {
          "evidence_ref": { "type": "string", "minLength": 2 },
          "point": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "cta_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["goal", "cta"],
        "properties": {
          "goal": { "type": "string", "enum": ["comments", "profile_visit", "link_click", "save", "share"] },
          "cta": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "first_comment_goal": { "type": "string", "minLength": 3 },
    "reply_seed_topics": { "type": "array", "items": { "type": "string" } },
    "hard_rules": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
