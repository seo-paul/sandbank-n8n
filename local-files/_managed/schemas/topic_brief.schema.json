{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TopicBrief",
  "type": "object",
  "required": ["topic", "angle", "why_now", "platform_recommendation", "confidence"],
  "properties": {
    "topic": { "type": "string", "minLength": 5 },
    "angle": { "type": "string", "minLength": 10 },
    "why_now": { "type": "string", "minLength": 10 },
    "platform_recommendation": {
      "type": "array",
      "items": { "type": "string", "enum": ["linkedin", "instagram", "reddit"] },
      "minItems": 1
    },
    "format_recommendation": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
