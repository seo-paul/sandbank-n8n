{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResearchOutput",
  "type": "object",
  "required": [
    "research_verdict",
    "retrieval_summary",
    "topic_candidates",
    "evidence_packets",
    "missing_evidence",
    "next_queries",
    "discarded_signals",
    "query_diagnostics"
  ],
  "properties": {
    "research_verdict": {
      "type": "string",
      "enum": ["strong", "usable", "weak"]
    },
    "retrieval_summary": {
      "type": "object",
      "required": [
        "external_signal_count",
        "allowed_signal_count",
        "blocked_signal_count",
        "distinct_domains",
        "primary_source_count",
        "source_mix",
        "resource_class_mix",
        "review_required_signal_count",
        "external_evidence_ready"
      ],
      "properties": {
        "external_signal_count": { "type": "number", "minimum": 0 },
        "allowed_signal_count": { "type": "number", "minimum": 0 },
        "blocked_signal_count": { "type": "number", "minimum": 0 },
        "distinct_domains": { "type": "number", "minimum": 0 },
        "primary_source_count": { "type": "number", "minimum": 0 },
        "source_mix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_type", "count"],
            "properties": {
              "source_type": { "type": "string", "enum": ["official", "research", "media", "community", "vendor"] },
              "count": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "resource_class_mix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["resource_class", "count"],
            "properties": {
              "resource_class": {
                "type": "string",
                "enum": [
                  "official_product_or_platform_docs",
                  "official_standards_or_regulation",
                  "first_party_original_data",
                  "industry_benchmark_or_survey",
                  "operator_case_study",
                  "topic_specific_research",
                  "community_signal",
                  "general_media",
                  "vendor_content",
                  "low_value_aggregator"
                ]
              },
              "count": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "review_required_signal_count": { "type": "number", "minimum": 0 },
        "external_evidence_ready": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "topic_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "angle_id",
          "angle",
          "audience_problem",
          "why_now",
          "evidence_refs",
          "novelty_score",
          "confidence",
          "engagement_hypothesis",
          "selection_reason",
          "channel_fit"
        ],
        "properties": {
          "angle_id": { "type": "string", "minLength": 2 },
          "angle": { "type": "string", "minLength": 5 },
          "audience_problem": { "type": "string", "minLength": 5 },
          "why_now": { "type": "string", "minLength": 5 },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
          "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "engagement_hypothesis": { "type": "string", "minLength": 5 },
          "selection_reason": { "type": "string", "minLength": 5 },
          "channel_fit": {
            "type": "object",
            "required": ["linkedin", "reddit"],
            "properties": {
              "linkedin": { "type": "number", "minimum": 0, "maximum": 1 },
              "reddit": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "claim",
          "source_title",
          "source_ref",
          "domain",
          "retrieval_query",
          "published_at",
          "source_type",
          "resource_class",
          "source_tier",
          "authority",
          "freshness",
          "allowed_usage",
          "topic_fit_score",
          "evidence_strength_score",
          "citation_readiness_score",
          "transferability_score",
          "commercial_bias_score",
          "review_required",
          "support_type",
          "why_it_matters",
          "risk_or_bias",
          "linkedin_use",
          "reddit_use"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 2 },
          "claim": { "type": "string", "minLength": 5 },
          "source_title": { "type": "string", "minLength": 3 },
          "source_ref": { "type": "string", "minLength": 3 },
          "domain": { "type": "string", "minLength": 3 },
          "retrieval_query": { "type": "string", "minLength": 3 },
          "published_at": { "type": "string" },
          "source_type": { "type": "string", "enum": ["official", "research", "media", "community", "vendor"] },
          "resource_class": {
            "type": "string",
            "enum": [
              "official_product_or_platform_docs",
              "official_standards_or_regulation",
              "first_party_original_data",
              "industry_benchmark_or_survey",
              "operator_case_study",
              "topic_specific_research",
              "community_signal",
              "general_media",
              "vendor_content",
              "low_value_aggregator"
            ]
          },
          "source_tier": { "type": "string", "enum": ["primary", "supporting", "community_signal"] },
          "authority": { "type": "string", "enum": ["high", "medium", "low"] },
          "freshness": { "type": "string", "enum": ["current", "recent", "dated", "timeless"] },
          "allowed_usage": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["background", "fact", "quote", "comparison", "counterpoint", "example"] }
          },
          "topic_fit_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_strength_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "citation_readiness_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "transferability_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "commercial_bias_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "review_required": { "type": "boolean" },
          "support_type": { "type": "string", "enum": ["data", "quote", "example", "trend", "counterpoint"] },
          "why_it_matters": { "type": "string", "minLength": 5 },
          "risk_or_bias": { "type": "string", "minLength": 3 },
          "linkedin_use": { "type": "string", "minLength": 3 },
          "reddit_use": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "next_queries": { "type": "array", "items": { "type": "string" } },
    "discarded_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref", "reason"],
        "properties": {
          "source_ref": { "type": "string", "minLength": 2 },
          "reason": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "query_diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query", "status", "result_count", "notes"],
        "properties": {
          "query": { "type": "string", "minLength": 3 },
          "status": { "type": "string", "enum": ["ok", "empty", "blocked", "failed"] },
          "result_count": { "type": "number", "minimum": 0 },
          "notes": { "type": "string", "minLength": 2 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
