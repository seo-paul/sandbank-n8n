{
  "name": "System Verbindungen pruefen",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "manual-1",
      "name": "Manuell starten",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -900,
        220
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://searxng:8080/search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "sandbank"
            },
            {
              "name": "format",
              "value": "json"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "http-search",
      "name": "Websuche Verbindung pruefen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -620,
        120
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ ($env.OLLAMA_BASE_URL || \"http://host.docker.internal:11434\").replace(/\\/+$/, \"\") + \"/api/tags\" }}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "http-model",
      "name": "KI Modell erreichbar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -620,
        220
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.OBSIDIAN_REST_URL + \"/\"}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{\"Bearer \" + $env.OBSIDIAN_REST_API_KEY}}"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": "={{($env.OBSIDIAN_ALLOW_INSECURE_TLS || \"false\") === \"true\"}}",
          "timeout": 15000
        }
      },
      "id": "http-obsidian",
      "name": "Obsidian API erreichbar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -620,
        320
      ]
    }
  ],
  "connections": {
    "Manuell starten": {
      "main": [
        [
          {
            "node": "Websuche Verbindung pruefen",
            "type": "main",
            "index": 0
          },
          {
            "node": "KI Modell erreichbar",
            "type": "main",
            "index": 0
          },
          {
            "node": "Obsidian API erreichbar",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "saveManualExecutions": true
  },
  "versionId": "be0eb23c-6ea4-4ad0-91bb-c88e2e2ebfce"
}
